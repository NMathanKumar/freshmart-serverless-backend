# ===========================================
# FRESHMART BACKEND - COMPLETE ENVIRONMENT TEMPLATE
# Copy this file to .env and replace placeholders with real values.
# ===========================================

# --- Runtime ---
NODE_ENV=development
APP_NAME=freshmart-backend
SERVICE_NAME=freshmart-backend
PORT=4000
API_PREFIX=/api/v1
LOG_LEVEL=info

# --- CORS ---
CORS_ALLOWED_ORIGINS=http://localhost:3000
CORS_ALLOW_CREDENTIALS=false

# --- Auth / JWT ---
# NOTE: Auth module is prepared for Amazon Cognito replacement in a future sprint.
# JWT is used for local/non-Cognito environments only.
JWT_SECRET=0123456789abcdef0123456789abcdef0123456789abcdef
JWT_REFRESH_SECRET=fedcba9876543210fedcba9876543210fedcba9876543210
JWT_EXPIRES_IN=1d
JWT_REFRESH_EXPIRES_IN=7d
BCRYPT_SALT_ROUNDS=10

# --- Rate Limiting / API ---
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300

# --- Legacy local config still referenced by workflow/runtime modules ---
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=root
DB_NAME=freshmart_db
DB_CONNECTION_LIMIT=10
TAX_PERCENTAGE=5

# --- AWS Region / EventBridge ---
AWS_REGION=ap-southeast-1
AWS_EVENT_BUS_NAME=freshmart-events
AWS_EVENT_SOURCE=freshmart-backend

# --- AWS S3 ---
AWS_S3_BUCKET=freshmart-media-bucket

# --- AWS SNS Topics ---
AWS_SNS_LOW_STOCK_TOPIC_ARN=arn:aws:sns:ap-southeast-1:769044546162:freshmart-low-stock
AWS_SNS_ORDER_PLACED_TOPIC_ARN=arn:aws:sns:ap-southeast-1:769044546162:freshmart-order-placed
AWS_SNS_ORDER_READY_TOPIC_ARN=arn:aws:sns:ap-southeast-1:769044546162:freshmart-order-ready
AWS_SNS_PAYMENT_SUCCESS_TOPIC_ARN=arn:aws:sns:ap-southeast-1:769044546162:freshmart-payment-success
AWS_SNS_PAYMENT_FAILURE_TOPIC_ARN=arn:aws:sns:ap-southeast-1:769044546162:freshmart-payment-failure
AWS_SNS_NOTIFICATION_TOPIC_ARN=arn:aws:sns:ap-southeast-1:769044546162:freshmart-notifications
AWS_SNS_REPORT_TOPIC_ARN=arn:aws:sns:ap-southeast-1:769044546162:freshmart-reports

# --- AWS SQS Queues ---
AWS_SQS_INVENTORY_QUEUE_URL=https://sqs.ap-southeast-1.amazonaws.com/769044546162/freshmart-inventory-queue
AWS_SQS_EMAIL_QUEUE_URL=https://sqs.ap-southeast-1.amazonaws.com/769044546162/freshmart-email-queue
AWS_SQS_NOTIFICATION_QUEUE_URL=https://sqs.ap-southeast-1.amazonaws.com/769044546162/freshmart-notification-queue
AWS_SQS_ANALYTICS_QUEUE_URL=https://sqs.ap-southeast-1.amazonaws.com/769044546162/freshmart-analytics-queue
AWS_SQS_INVENTORY_DLQ_URL=https://sqs.ap-southeast-1.amazonaws.com/769044546162/freshmart-inventory-dlq
AWS_SQS_EMAIL_DLQ_URL=https://sqs.ap-southeast-1.amazonaws.com/769044546162/freshmart-email-dlq
AWS_SQS_NOTIFICATION_DLQ_URL=https://sqs.ap-southeast-1.amazonaws.com/769044546162/freshmart-notification-dlq
AWS_SQS_ANALYTICS_DLQ_URL=https://sqs.ap-southeast-1.amazonaws.com/769044546162/freshmart-analytics-dlq

# --- DynamoDB Tables ---
# Provisioned by Terraform — values injected at deploy time via Lambda environment variables.
DDB_TABLE_AUTH_USERS=freshmart-auth-users
DDB_TABLE_USER_PROFILES=freshmart-user-profiles
DDB_TABLE_PRODUCTS=freshmart-products
DDB_TABLE_CARTS=freshmart-carts
DDB_TABLE_ORDERS=freshmart-orders
DDB_TABLE_PAYMENTS=freshmart-payments
DDB_TABLE_INVENTORY=freshmart-inventory
DDB_TABLE_NOTIFICATIONS=freshmart-notifications
DDB_TABLE_ANALYTICS=freshmart-analytics
DDB_TABLE_ADMIN=freshmart-admin
